{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "helpers/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
